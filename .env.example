# Variabili d'Ambiente - Template

# Google Gemini API Key
GEMINI_API_KEY=tuo_codice_api_qui

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# CORS Configuration
CORS_ORIGINS=http://localhost:5000,http://localhost:8000,https://www.pinizzotto.it

# Session Configuration
SESSION_MAX_MESSAGES=50
SESSION_TIMEOUT=3600

# API Configuration
API_TIMEOUT=30
API_MAX_MESSAGE_LENGTH=1000
API_RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=chatbot.log

# --- PRODUZIONE (Render / Heroku) ---
# 1. Nel Dashboard di Render -> Settings -> Environment Variables
# 2. Aggiungi GEMINI_API_KEY con il tuo valore segreto
# 3. Imposta FLASK_ENV=production
# 4. Imposta CORS_ORIGINS con l'URL del tuo sito (es: https://pinizzotto.onrender.com)
# 5. Assicurati che lo Start Command sia: gunicorn app:app
